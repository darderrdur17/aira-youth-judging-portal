# Copy to .env.local and fill in real values. Never commit .env or .env.local.

# Supabase (from https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (https://resend.com) — for organiser reminder emails via the app API
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="AISG Judging Portal <no-reply@yourdomain.com>"

# Public site URL (local dev or production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
